# Modèle de variables d’environnement — non chargé par Next.js.
# À la racine du projet, créez un fichier .env.local (copier-coller ce fichier)
# et renseignez les valeurs. .env.local est ignoré par Git (.gitignore).
#
# Images /assets/imgg/… : laisser vide en prod (fichiers dans public/).
# Ne pas mettre https://www.le-repasseur.fr sur Vercel (www = l’app → 404).
# NEXT_PUBLIC_SITE_ASSET_BASE=https://www.le-repasseur.fr

# Optionnel : surcharger la config Firebase.
# Si vous laissez KEY= vide, les valeurs embarquées dans le code sont utilisées (voir firebase.ts).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin (serveur Node uniquement) — JSON du compte de service sur une ligne.
# Obligatoire pour : /api/checkout (lecture Stripe Firestore + paiement identifié),
# /api/admin/email-hook (vérification jeton admin).
# Permet aussi la lecture siteSettings/stripe (clés Stripe + price IDs).
# Firebase Console → Paramètres du projet → Comptes de service → Générer une nouvelle clé privée.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...",...}

# Stripe — secours si rien dans Firestore (voir Administration → Stripe sur le site)
STRIPE_SECRET_KEY=
# Identifiants de prix Stripe (Produits → chaque offre → Prix récurrent ou ponctuel → price_…)
# Offre découverte espace client (nouveaux inscrits) — paiement unique 1 €
STRIPE_PRICE_ESSAI_1EURO=
STRIPE_PRICE_MINO=
STRIPE_PRICE_SOLO=
STRIPE_PRICE_DUO=
STRIPE_PRICE_MARMO=
STRIPE_PRICE_SUPER_HEROS=
STRIPE_PRICE_PACK_5KG=
STRIPE_PRICE_PACK_10KG=
STRIPE_PRICE_RECHARGE_5KG=
# Alignement Firestore ↔ abonnements Stripe actifs (script `npm run sync:stripe`)
# Nécessite FIREBASE_SERVICE_ACCOUNT_JSON + STRIPE_SECRET_KEY. Dry-run par défaut ; `--apply` pour écrire (quotas inchangés ; ajoutez `--set-quotas` pour les réinitialiser).

# Webhook Stripe (renouvellements auto) — endpoint secret `whsec_...`
# Dashboard Stripe → Développeurs → Webhooks → URL : https://VOTRE-DOMAINE/api/stripe/webhook
# Événements conseillés : invoice.paid, invoice.upcoming (promos / tarifs catalogue au renouvellement), checkout.session.completed
STRIPE_WEBHOOK_SECRET=
# Portail client Stripe (retour après gestion abonnement)
STRIPE_BILLING_PORTAL_RETURN_URL=https://www.le-repasseur.fr/espace-client
# Pendant la migration : si clé ou prix manquant, renvoie l’URL recap.html de l’ancien site (optionnel)
CHECKOUT_LEGACY_FALLBACK=

# Factures PDF générées sur le site (espace client)
COMPANY_LEGAL_NAME=Umbrella Services
COMPANY_TRADE_NAME=Le Repasseur
COMPANY_ADDRESS_LINE1=15 Avenue Thiers
COMPANY_ADDRESS_LINE2=06600 Antibes
COMPANY_SIRET=
COMPANY_TVA_INTRA=
COMPANY_EMAIL=contact@le-repasseur.fr
COMPANY_PHONE=07 67 12 36 39
COMPANY_WEBSITE=www.le-repasseur.fr
COMPANY_VAT_MENTION=TVA non applicable, article 293 B du Code général des impôts.
COMPANY_IBAN=
